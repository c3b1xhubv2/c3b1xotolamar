# ============================================================
#  Environment Variables — isi di Vercel (Settings > Environment
#  Variables) atau di file .env untuk `vercel dev` (lokal).
# ============================================================

# --- Supabase ---
# Ambil dari: Supabase Dashboard > Project Settings > API
SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
SUPABASE_ANON_KEY=eyJhbGciOi...            # anon public key (boleh diekspos)
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOi...    # service_role key (RAHASIA, server only!)

# --- Kunci enkripsi App Password ---
# Buat dengan perintah:  openssl rand -hex 32
# Harus 64 karakter hex. JANGAN diubah setelah ada data tersimpan.
ENCRYPTION_KEY=ganti_dengan_64_karakter_hex
